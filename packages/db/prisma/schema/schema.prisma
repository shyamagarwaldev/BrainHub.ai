generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContentSource {
  YOUTUBE
  X
  ARTICLE
  NOTE
  PDF
  WEBPAGE
}

enum ProcessingStatus {
  EXTRACTING
  CLEANING
  COMPLETED
  EMBEDDING
  PENDING
  FAILED
  PROCESSING
  EXTRACTED
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
}
